Imports System.Runtime.InteropServices
Imports Inventor
Imports Microsoft.VisualBasic
Imports System

<ComVisible(True)>
<Guid("87654321-4321-4321-4321-ABCDEF123456")>
Public Class StandardAddInServer
    Implements Inventor.ApplicationAddInServer

    Private m_inventorApplication As Inventor.Application
    Private m_addInSite As ApplicationAddInSite
    Private m_userInterfaceMgr As UserInterfaceManager
    Private m_ribbon As Ribbon
    Private m_cloneButton As ButtonDefinition
    Private m_plateStatusButton As ButtonDefinition
    Private m_plateDocSettings As PlateDocumentSettings

    Public Sub Activate(addInSiteObject As ApplicationAddInSite, firstTime As Boolean) Implements ApplicationAddInServer.Activate
        Try
            m_addInSite = addInSiteObject
            m_inventorApplication = addInSiteObject.Application
            m_userInterfaceMgr = m_inventorApplication.UserInterfaceManager

            ' Initialize PlateDocumentSettings to hook event handlers
            m_plateDocSettings = New PlateDocumentSettings(m_inventorApplication)
            System.Diagnostics.Debug.WriteLine("PlateDocumentSettings initialized successfully")

            If firstTime Then
                AddToUserInterface()
            End If
                
        Catch ex As Exception
            System.Diagnostics.Debug.WriteLine("Error activating add-in: " & ex.Message)
            System.Windows.Forms.MessageBox.Show("Add-In Activation Error: " & ex.Message & vbCrLf & vbCrLf & ex.StackTrace, "AssemblyClonerAddIn Error")
        End Try
    End Sub

    Public Sub Deactivate() Implements ApplicationAddInServer.Deactivate
        Try
            ' Cleanup PlateDocumentSettings
            If m_plateDocSettings IsNot Nothing Then
                m_plateDocSettings.Cleanup()
                m_plateDocSettings = Nothing
            End If

            RemoveFromUserInterface()
            m_inventorApplication = Nothing
            m_addInSite = Nothing
            m_userInterfaceMgr = Nothing
        Catch ex As Exception
            MsgBox("Error deactivating add-in: " & ex.Message)
        End Try
    End Sub

    Public ReadOnly Property Automation() As Object Implements ApplicationAddInServer.Automation
        Get
            Return Nothing
        End Get
    End Property

    Public Sub ExecuteCommand(commandID As Integer) Implements ApplicationAddInServer.ExecuteCommand
        ' Not used in this add-in
    End Sub

    Private Sub AddToUserInterface()
        Try
            m_ribbon = m_userInterfaceMgr.Ribbons.Item("Assembly")
            Dim tab As RibbonTab = m_ribbon.RibbonTabs.Item("id_TabManage")

            ' Clone Assembly button
            m_cloneButton = m_inventorApplication.CommandManager.ControlDefinitions.AddButtonDefinition(
                "Clone Assembly & Patch iLogic", "CloneAssemblyButton", CommandTypesEnum.kQueryOnlyCmdType,
                "{87654321-4321-4321-4321-ABCDEF123456}", "Clone the current assembly and patch iLogic rules",
                "Clone Assembly", , , ButtonDisplayEnum.kDisplayTextInLearningMode)

            AddHandler m_cloneButton.OnExecute, AddressOf CloneButton_OnExecute

            Dim panel As RibbonPanel = tab.RibbonPanels.Item("id_Panel_AssemblyManage")
            panel.CommandControls.AddButton(m_cloneButton)
            
            ' Plate Settings Status button (read-only info)
            m_plateStatusButton = m_inventorApplication.CommandManager.ControlDefinitions.AddButtonDefinition(
                "Plate Zero-Decimal Fix: ACTIVE", "PlateStatusButton", CommandTypesEnum.kQueryOnlyCmdType,
                "{87654321-PLATE-STATUS-GUID}", "Background service auto-applies zero-decimal fix to plate parts on save",
                "Plate Fix: ON", , , ButtonDisplayEnum.kDisplayTextInLearningMode)

            AddHandler m_plateStatusButton.OnExecute, AddressOf PlateStatusButton_OnExecute

            panel.CommandControls.AddButton(m_plateStatusButton)
            
        Catch ex As Exception
            MsgBox("Error adding to UI: " & ex.Message)
        End Try
    End Sub

    Private Sub RemoveFromUserInterface()
        Try
            If m_cloneButton IsNot Nothing Then
                m_cloneButton.Delete()
                m_cloneButton = Nothing
            End If
            
            If m_plateStatusButton IsNot Nothing Then
                m_plateStatusButton.Delete()
                m_plateStatusButton = Nothing
            End If
        Catch ex As Exception
            MsgBox("Error removing from UI: " & ex.Message)
        End Try
    End Sub

    Private Sub CloneButton_OnExecute()
        Try
            Dim cloner As New AssemblyCloner(m_inventorApplication)
            cloner.CloneAndPatch()
        Catch ex As Exception
            MsgBox("Error cloning assembly: " & ex.Message)
        End Try
    End Sub
    
    Private Sub PlateStatusButton_OnExecute()
        Try
            System.Windows.Forms.MessageBox.Show(
                "PLATE DOCUMENT SETTINGS - Background Service" & vbCrLf & vbCrLf &
                "Status: ACTIVE ✓" & vbCrLf & vbCrLf &
                "What it does:" & vbCrLf &
                "• Monitors all plate parts (PL/S355JR in part number)" & vbCrLf &
                "• Auto-applies Document Settings on save:" & vbCrLf &
                "  - Linear Dimension Precision = 0 decimals" & vbCrLf &
                "  - Dimension Display = Display as value" & vbCrLf &
                "  - Parameter Input = Display as expression" & vbCrLf &
                "• Forces BOM refresh in parent assemblies" & vbCrLf & vbCrLf &
                "Result: BOM shows '1200' instead of '1200.000'" & vbCrLf & vbCrLf &
                "No user action required - works automatically!",
                "Plate Settings Status",
                System.Windows.Forms.MessageBoxButtons.OK,
                System.Windows.Forms.MessageBoxIcon.Information)
        Catch ex As Exception
            MsgBox("Error showing status: " & ex.Message)
        End Try
    End Sub
End Class